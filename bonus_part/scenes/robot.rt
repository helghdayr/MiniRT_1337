# Side panel detail
cy 4.0,0.8,4.15 0,0,1 1.2 0.1 50,160,100

# ============================================================
# ENVIRONMENT DETAILS
# ============================================================

# Glowing energy cube on floor (decorative)
sp -1.5,0.0,5 0.6 255,160,20

# Small cable spool cylinder
cy 2.5,-0.6,7 0,0,1 0.8 1.0 100,90,85

# Overhead pipe 1
cy -6,8,6 1,0,0 0.25 14 130,125,120

# Overhead pipe 2
cy -6,7.2,9 1,0,0 0.18 12 100,95,90

# Pipe junction sphere
sp 1.0,8.0,6 0.28 120,115,110

# Warning light (red sphere on pipe)
sp -2.5,8.0,6 0.2 255,40,20

# ============================================================
# END OF SCENE
